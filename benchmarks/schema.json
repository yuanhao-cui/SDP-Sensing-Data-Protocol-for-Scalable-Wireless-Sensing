{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["model", "dataset", "accuracy_mean", "accuracy_std", "seeds", "submitter", "date"],
  "properties": {
    "model": {"type": "string"},
    "dataset": {"type": "string", "enum": ["widar", "gait", "xrf55", "elderAL", "zte"]},
    "accuracy_mean": {"type": "number", "minimum": 0, "maximum": 1},
    "accuracy_std": {"type": "number", "minimum": 0},
    "seeds": {"type": "array", "items": {"type": "integer"}, "minItems": 3},
    "params_M": {"type": "number", "minimum": 0},
    "training_config": {"type": "object"},
    "paper_url": {"type": "string", "format": "uri"},
    "code_url": {"type": "string", "format": "uri"},
    "submitter": {"type": "string"},
    "date": {"type": "string", "format": "date"}
  }
}
